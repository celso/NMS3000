{
  "extends": "./tsconfig.node.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.worker.tsbuildinfo",
    "types": [
      "@cloudflare/workers-types/2023-07-01",
      "vite/client"
    ],

    /* Path aliases */
    "baseUrl": ".",
    "paths": {
      "~lib/*": ["lib/*"]
    }
  },
  "include": ["worker", "worker-configuration.d.ts", "lib"]
}
